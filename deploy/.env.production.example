# ArtisanFlow ERP — configuration de PRODUCTION
# Copier vers /var/www/artisanflow/.env puis : php artisan key:generate

APP_NAME=ArtisanFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://artisanflow.example.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# Niveau de log raisonnable en prod
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# --- Base de données (MariaDB local) ---
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artisanflow
DB_USERNAME=artisanflow
DB_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort

# --- Sessions / cache / file d'attente ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- E-mail (relances de factures) : renseigner un vrai SMTP en prod ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.votre-fournisseur.fr
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@artisanflow.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Assistant IA (laisser vide = mode gratuit basé données) ---
ASSISTANT_API_KEY=
ASSISTANT_BASE_URL=https://api.groq.com/openai/v1
ASSISTANT_MODEL=llama-3.3-70b-versatile
ASSISTANT_TIMEOUT=30
